# ── Backend ─────────────────────────────────────────────
# Local MySQL (MySQL80 service running on 3306).
# Replace USER/PASSWORD with your MySQL credentials.
DATABASE_URL="mysql://root:password@localhost:3306/credit_core"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1d"

# Local disk storage for uploaded documents (relative to backend cwd).
UPLOAD_DIR="./uploads"

BACKEND_PORT=3000

# Comma-separated origins allowed by CORS (dev).
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# ── Frontends (Vite) ────────────────────────────────────
# Each web app reads VITE_API_URL at build/dev time.
VITE_API_URL="http://localhost:3000"
