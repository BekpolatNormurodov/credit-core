# Network resilience for installs — the prod build runs 5 images' `npm ci`/`npm install`
# concurrently, which can saturate the link and drop connections (ECONNRESET). Retry with backoff
# instead of failing the whole build. Harmless for local dev.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
