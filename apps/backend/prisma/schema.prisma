generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  MODERATOR
  DIRECTOR
  ADMIN
}

enum ProductType {
  REAL_ESTATE
  AUTO
}

enum CaseStatus {
  DRAFT
  MODERATION
  DIRECTOR_REVIEW
  ADMIN_FINALIZE
  FINALIZED
  REJECTED
  CANCELLED
}

enum WorkflowDecision {
  SUBMIT
  APPROVE
  RETURN
  FINALIZE
  CANCEL
  REOPEN
}

enum DocumentType {
  NOTARY
  SCAN
  PASSPORT
  COLLATERAL_PHOTO
  TECH_PASSPORT
  GEN_DOVERNOST
  DIRECTOR_FINAL
  GENERATED_PDF
  CHAT
  OTHER
}

enum Gender {
  MALE
  FEMALE
}

enum LoanType {
  MICROLOAN
  MICROCREDIT
}

enum RepaymentMethod {
  ANNUITY
  DIFFERENTIATED
}

enum ScoringVerdict {
  APPROVED
  REFER_COMMITTEE
  BELOW_MIN
  FAILED_INCOME
  FAILED_PROBLEM_LOANS
}

model Branch {
  id         String       @id @default(cuid())
  name       String
  symbol     String       @unique // filial id symbol, e.g. "BR"
  region     String?
  users      User[]
  // Moderators responsible for this branch (many-to-many; a branch may have
  // several moderators and a moderator may cover several branches).
  moderators User[]       @relation("BranchModerators")
  cases      CreditCase[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model User {
  id                String          @id @default(cuid())
  fullName          String
  login             String          @unique
  passwordHash      String
  plainPassword     String? // admin-visible credential (internal tool — see note)
  avatarPath        String?
  phone             String?
  role              Role
  branch            Branch?         @relation(fields: [branchId], references: [id])
  branchId          String?
  // Branches this moderator is responsible for (m-n, see Branch.moderators).
  moderatedBranches Branch[]        @relation("BranchModerators")
  isActive          Boolean         @default(true)
  createdCases      CreditCase[]    @relation("CaseCreatedBy")
  signedCases       CaseSignature[] @relation("CaseSignedBy")
  documents         Document[]
  events            WorkflowEvent[]
  auditLogs         AuditLog[]      @relation("AuditActor")
  sentMessages      Message[]       @relation("MessageSender")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([branchId])
}

model CreditCase {
  id          String      @id @default(cuid())
  number      String      @unique
  productType ProductType
  status      CaseStatus  @default(DRAFT)
  amount      Decimal?    @db.Decimal(18, 2)
  termMonths  Int?
  katmPrice   Decimal?    @db.Decimal(18, 2)

  // Auto contract number (assigned on submit to moderator) — separate from `number` (ariza id).
  // Format: "{contractGlobalNo} MFL {contractYearlyNo} {contractBranchSym}" e.g. "2012 MFL 1320 PS".
  contractGlobalNo  Int?
  contractYearlyNo  Int?
  contractBranchSym String?
  contractNumber    String?      @unique
  isReMfl           Boolean      @default(false)
  reMflSource       CreditCase?  @relation("ReMfl", fields: [reMflSourceId], references: [id], onDelete: SetNull)
  reMflSourceId     String?
  reMflChildren     CreditCase[] @relation("ReMfl")

  // SLA timer for the current step (set on each transition into a deadline step).
  stepStartedAt   DateTime?
  stepDeadlineAt  DateTime?
  overdueNotified Boolean   @default(false) // overdue notification already sent for this step
  pausedAt        DateTime? // set while the case is on hold — SLA timer is suspended
  pauseUntil      DateTime? // chosen auto-resume moment for the current pause (business-day window)

  // Soft-delete (archive): a draft is never hard-deleted — these are set so it moves to the Arxiv
  // view. deletedById is the actor; deletedReason is mandatory. Restoring clears all three.
  deletedAt     DateTime?
  deletedReason String?   @db.Text
  deletedById   String?

  branch      Branch? @relation(fields: [branchId], references: [id])
  branchId    String?
  createdBy   User    @relation("CaseCreatedBy", fields: [createdById], references: [id])
  createdById String

  borrower     Borrower?
  guarantors   Guarantor[]
  collaterals  Collateral[]
  valuationAct ValuationAct?
  documents    Document[]
  events       WorkflowEvent[]
  auditLogs    AuditLog[]
  importJobs   ImportJob[]
  messages     Message[]

  creditLine        CreditLine?
  employment        Employment?
  affordability     Affordability?
  creditHistory     CreditHistory?
  scoring           ScoringResult?
  incomeCertificate IncomeCertificate?
  disbursement      DisbursementDetail?

  /// The director's E-IMZO signature, once they have signed. Its absence means the case rests on
  /// the workflow record alone — which is true of everything issued before this feature.
  signature   CaseSignature?
  signedAt    DateTime?
  /// When the document set was rendered and frozen to disk. From this moment the stored files are
  /// the issued documents; the templates are no longer consulted for this case.
  docsFrozenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([stepDeadlineAt])
}

/// The director's E-IMZO signature over the case's frozen document set.
///
/// `verified` is the whole story of this table. Producing a signature needs nothing but the
/// director's key; *checking* one needs E-IMZO-SERVER and a NIC contract, which we do not have.
/// So the row is evidence, not proof: it is a real PKCS#7 made by a real key on the director's own
/// machine, and a third party with E-IMZO-SERVER can verify it — we cannot, yet. Until we can,
/// nothing in the UI may call a document «tasdiqlangan» on the strength of this row alone.
///
/// One signature per case: the signed payload is a manifest listing every generated document and
/// its digest, so a single key press covers the whole set rather than 19 separate passwords.
model CaseSignature {
  id             String     @id @default(cuid())
  case           CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId         String     @unique
  /// base64 PKCS#7/CMS with the manifest attached.
  pkcs7          String     @db.LongText
  /// The manifest exactly as it was signed — so what the signature covers stays readable later.
  manifest       Json
  /// Digest of the manifest bytes handed to the client. The server re-derives this at commit.
  manifestSha256 String
  /// Set only once an E-IMZO-SERVER has actually checked it. Never set by the client.
  verified       Boolean    @default(false)
  verifiedAt     DateTime?
  /// Untrusted, informational: the key's alias/name as the client reported it.
  signerInfo     Json?
  signedBy       User       @relation("CaseSignedBy", fields: [signedById], references: [id])
  signedById     String
  createdAt      DateTime   @default(now())
}

/// A rendered-but-unsigned document set awaiting its signature.
///
/// The director signs bytes, so the server must know exactly which bytes it handed out: without
/// this row a client could sign anything at all and we would store it against the case.
/// Short-lived by design — one signing attempt.
model CaseSignChallenge {
  id             String   @id @default(cuid())
  caseId         String
  /// The director who asked. Only they may complete it.
  userId         String
  /// Digest of the manifest handed to the client; the returned PKCS#7 must cover exactly this.
  manifestSha256 String
  /// The manifest itself, carried here rather than re-derived at commit. It stamps a `signedAt`
  /// that cannot be recomputed later, and re-deriving it from the client's copy would mean
  /// trusting the client with the very thing this row exists to pin down.
  manifest       Json
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([caseId])
  @@index([expiresAt])
}

/// Company-wide contract-number counters. id = "global" (never resets) or a year like "2026".
model ContractCounter {
  id    String @id
  value Int    @default(0)
}

/**
 * Admin-configured SLA per workflow step (business days). One row per deadline step.
 */
model StepSetting {
  step         CaseStatus @id
  businessDays Int        @default(2)
  enabled      Boolean    @default(true) // false = step timer off (no deadline)
  updatedAt    DateTime   @updatedAt
}

/**
 * Singleton global config (pause limit + loan economics rates). id is always "default".
 */
model AppConfig {
  id            String   @id @default("default")
  maxPauseDays  Int      @default(5) // max business days a case may stay paused
  markupPercent Float    @default(0.41) // klient ustama foizi
  bankRate      Float    @default(0.28) // bank yillik foiz stavkasi
  taxRate       Float    @default(0.12) // daromad solig'i
  nplRate       Float    @default(0.05) // NPL (to'lanmaslik) foizi
  minRate       Float    @default(0.55) // klient kredit yillik foizi — pastki chegara
  maxRate       Float    @default(0.60) // yuqori chegara (moderator shu gacha ko'taradi)
  updatedAt     DateTime @updatedAt
}

model Borrower {
  id             String     @id @default(cuid())
  case           CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId         String     @unique
  fullName       String
  passportSeries String?
  passportNumber String?
  pinfl          String?
  birthDate      DateTime?
  address        String?    @db.Text
  phone          String?

  gender            Gender?
  citizenship       String?
  placeOfBirth      String?
  previousName      String?
  inn               String?
  passportIssuer    String?   @db.Text
  passportIssueDate DateTime?
  passportExpiry    DateTime?
  regAddress        String?   @db.Text
  regLandmark       String?
  regTenure         String?
  regMatchesActual  Boolean?
  actualAddress     String?   @db.Text
  actualLandmark    String?
  actualTenure      String?
  phones             Json?
  closeContacts      Json?     // [{ relation, fullName, phone }] — yaqin kishilar (2 majburiy, 5 gacha)
  entrepreneurType   String?   // >100M: yakka tartibdagi tadbirkor / o'zini o'zi band qilgan
  entrepreneurCertNo String?   // guvohnoma raqami
  maritalStatus     String?
  /// b3!D42 «Яшаш жойи тури» — scoring input (мулкий хукук / ижара-ётоқхона / иш берувчи).
  housingType       String?
  /// b3!D43 «Банкларда омонат хисобракамлари» — scoring input (deposit size band).
  depositBand       String?
  familySize        Int?
  childrenCount     Int?
  education         String?
  residenceDuration String?
  ownsHome          String?
  depositsBand      String?
}

// Kafil (guarantor) — a case may have several.
model Guarantor {
  id             String     @id @default(cuid())
  case           CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId         String
  fullName       String
  passportSeries String?
  passportNumber String?
  pinfl          String?
  phone          String?
  relation       String? // qarz oluvchiga munosabati

  @@index([caseId])
}

// Unified collateral — a case can have several (e.g. 2 flats + 1 car).
model Collateral {
  id               String      @id @default(cuid())
  case             CreditCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId           String
  type             ProductType // REAL_ESTATE | AUTO
  agreedValue      Decimal?    @db.Decimal(18, 2)
  agreedValueWords String?     @db.Text

  // Real estate fields
  realtyKind       String?   // HOUSE | APARTMENT (Hovli | Kvartira), for type = REAL_ESTATE
  address          String?   @db.Text
  registryNo       String?
  propertyType     String?
  cadastreNo       String?
  registrationDate DateTime?
  totalAreaM2      Float?
  livingAreaM2     Float?
  roomNames        String?   @db.Text
  roomCount        Int?

  // Auto fields
  techPassportNo   String?
  techPassportDate DateTime?
  model            String?
  stateNumber      String?
  bodyType         String?
  bodyNo           String?
  engineNo         String?
  chassis          String?
  color            String?
  year             Int?
  mileage          Int?

  landAreaM2   Float?
  usableAreaM2 Float?
  position     Int?

  owners    CollateralOwner[]
  createdAt DateTime          @default(now())

  @@index([caseId])
}

model CollateralOwner {
  id             String     @id @default(cuid())
  collateral     Collateral @relation(fields: [collateralId], references: [id], onDelete: Cascade)
  collateralId   String
  fullName       String
  passportSeries String?
  passportNumber String?
  pinfl          String?
  sharePercent   Float?

  isBorrowerOwner Boolean?
  birthDate       DateTime?
  passportIssuer  String?   @db.Text
  regAddress      String?   @db.Text
}

model ValuationAct {
  id               String     @id @default(cuid())
  case             CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId           String     @unique
  actNo            String?
  actDate          DateTime?
  agreedValue      Decimal?   @db.Decimal(18, 2)
  agreedValueWords String?    @db.Text
}

model Document {
  id           String       @id @default(cuid())
  case         CreditCase?  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId       String?
  collateralId String? // optional: ties a photo/doc to a specific collateral
  title        String? // human label given on upload (per-collateral docs)
  description  String?      @db.Text // optional longer note
  type         DocumentType
  fileName     String
  storagePath  String
  mimeType     String?
  isGenerated  Boolean      @default(false)
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  // Legacy single-attachment back-relation (Message.documentId).
  message      Message?     @relation("MessageDoc")
  // Multi-attachment: a chat message can carry several files.
  attachedTo   Message?     @relation("MessageAttachments", fields: [messageId], references: [id], onDelete: SetNull)
  messageId    String?
  createdAt    DateTime     @default(now())

  @@index([caseId])
  @@index([messageId])
}

model Message {
  id          String     @id @default(cuid())
  case        CreditCase? @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId      String?
  sender      User       @relation("MessageSender", fields: [senderId], references: [id])
  senderId    String
  text        String?    @db.Text
  toRole      Role?
  toUserId    String? // directed to a single user (private to them + sender)
  document    Document?  @relation("MessageDoc", fields: [documentId], references: [id], onDelete: SetNull)
  documentId  String?    @unique
  attachments Document[] @relation("MessageAttachments")
  readBy      String?    @db.Text // comma-separated userIds who have read it
  editedAt    DateTime? // set when the sender edits the text
  createdAt   DateTime   @default(now())

  @@index([caseId])
  @@index([toUserId])
}

model WorkflowEvent {
  id         String           @id @default(cuid())
  case       CreditCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId     String
  fromStatus CaseStatus?
  toStatus   CaseStatus
  decision   WorkflowDecision
  actor      User             @relation(fields: [actorId], references: [id])
  actorId    String
  role       Role
  comment    String?          @db.Text
  createdAt  DateTime         @default(now())

  @@index([caseId])
}

model ImportJob {
  id             String      @id @default(cuid())
  sourceFileName String
  status         String      @default("PARSED")
  parsedJson     Json
  case           CreditCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  caseId         String?
  createdAt      DateTime    @default(now())
}

// ── SP-1: MKO workbook data model ───────────────────────────────────────

/// Singleton lender/MKO master data (id is always "default"). Source of requisites for all docs.
model Organization {
  id            String    @id @default("default")
  nameMixed     String
  nameUpper     String
  nameSuffix    String
  tradeMark     String? // Савдо белгиси, e.g. "PULMAKON" — printed on the generated forms
  directorShort String
  directorFull  String
  legalBasis    String    @default("Низом")
  address       String    @db.Text
  bankAccount   String
  bankMfo       String
  bankName      String
  /// Printed in the firm's requisites block on the contract and the bosh kelishuv.
  phone         String?
  inn           String
  licenseNo     String
  licenseDate   DateTime?
  updatedAt     DateTime  @updatedAt
}

/// РКЛ — revolving credit line master (one per case).
model CreditLine {
  id           String           @id @default(cuid())
  case         CreditCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId       String           @unique
  lineNumber   String?
  loanType     LoanType?
  amountAuto   Decimal?         @db.Decimal(18, 2)
  amountPolis  Decimal?         @db.Decimal(18, 2)
  amountTotal  Decimal?         @db.Decimal(18, 2)
  requiredCollateralAmount Decimal? @db.Decimal(18, 2) // mol-mulk (amountAuto) × 140% override; null = computed
  requiredInsuredAmount    Decimal? @db.Decimal(18, 2) // polis (amountPolis) × 130% insured-sum override
  termMonths   Int?
  lineDate     DateTime?
  lineMaturity DateTime?
  interestRate Decimal?         @db.Decimal(6, 4)
  penaltyRate  Decimal?         @db.Decimal(6, 4)
  orderNumber  String?
  tranches     Tranche[]
  insurance    InsurancePolicy?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

/// Individual drawdown under a credit line (микрозайм / микрокредит sub-contract).
model Tranche {
  id               String           @id @default(cuid())
  creditLine       CreditLine       @relation(fields: [creditLineId], references: [id], onDelete: Cascade)
  creditLineId     String
  trancheNo        Int
  applicationNo    String?
  applicationDate  DateTime?
  contractNo       String?
  contractDate     DateTime?
  principal        Decimal?         @db.Decimal(18, 2)
  termMonths       Int?
  maturity         DateTime?
  scheduleType     RepaymentMethod?
  monthlyPayment   Decimal?         @db.Decimal(18, 2)
  paymentDay       Int?             // har oy to'lov kuni — min(ariza kuni, 15)
  insurancePayment Decimal?         @db.Decimal(18, 2)
  schedule         PaymentSchedule?
  createdAt        DateTime         @default(now())

  @@index([creditLineId])
}

/// Amortization plan for one tranche (Annex 1). Rows generated by SP-4.
model PaymentSchedule {
  id               String          @id @default(cuid())
  tranche          Tranche         @relation(fields: [trancheId], references: [id], onDelete: Cascade)
  trancheId        String          @unique
  method           RepaymentMethod
  principal        Decimal         @db.Decimal(18, 2)
  termMonths       Int
  annualRate       Decimal         @db.Decimal(6, 4)
  disbursementDate DateTime
  paymentDayCap    Int             @default(25)
  generatedAt      DateTime        @default(now())
  installments     Installment[]
}

model Installment {
  id             String          @id @default(cuid())
  schedule       PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId     String
  seq            Int
  dueDate        DateTime
  openingBalance Decimal         @db.Decimal(18, 2)
  principal      Decimal         @db.Decimal(18, 2)
  interest       Decimal         @db.Decimal(18, 2)
  total          Decimal         @db.Decimal(18, 2)
  days           Int

  @@index([scheduleId])
}

/// Optional insurance policy backing the line (Д2 insurance block).
model InsurancePolicy {
  id               String     @id @default(cuid())
  creditLine       CreditLine @relation(fields: [creditLineId], references: [id], onDelete: Cascade)
  creditLineId     String     @unique
  insured          Boolean    @default(false)
  company          String?
  genAgreementNo   String?
  genAgreementDate DateTime?
  policyNo         String?
  policyIssueDate  DateTime?
  policyTermMonths Int?
  policyExpiry     DateTime?
  loanUnderPolicy  Decimal?   @db.Decimal(18, 2)
  insuredSum       Decimal?   @db.Decimal(18, 2)
  insuranceRate    Decimal?   @db.Decimal(6, 4)
  premium          Decimal?   @db.Decimal(18, 2)
}

/// Borrower employment (Д1 employment block). Scoring inputs: sector/sectorRiskCode, position, experience.
model Employment {
  id              String     @id @default(cuid())
  case            CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId          String     @unique
  employer        String?
  employerAddress String?    @db.Text
  sector          String?
  sectorRiskCode  Int?
  position        String?
  employedSince   String?
  experienceBand  String?
}

/// Income/expense affordability snapshot (Д1 rows 44–49, b3 DTI). Computed once, persisted.
model Affordability {
  id                   String     @id @default(cuid())
  case                 CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId               String     @unique
  avgMonthlyIncome     Decimal?   @db.Decimal(18, 2)
  mainActivityIncome   Decimal?   @db.Decimal(18, 2)
  secondaryIncome      Decimal?   @db.Decimal(18, 2)
  familyIncome         Decimal?   @db.Decimal(18, 2)
  otherIncome          Decimal?   @db.Decimal(18, 2)
  newLoanPayment       Decimal?   @db.Decimal(18, 2)
  utilitiesExpense     Decimal?   @db.Decimal(18, 2)
  familyExpense        Decimal?   @db.Decimal(18, 2)
  existingCreditBurden Decimal?   @db.Decimal(18, 2)
  otherExpense         Decimal?   @db.Decimal(18, 2)
  totalIncome          Decimal?   @db.Decimal(18, 2)
  totalCreditPayments  Decimal?   @db.Decimal(18, 2)
  totalExpenses        Decimal?   @db.Decimal(18, 2)
  dtiRatio             Float?
  surplus              Decimal?   @db.Decimal(18, 2)
  netAfterDebt         Decimal?   @db.Decimal(18, 2)
  computedAt           DateTime   @default(now())
}

/// Credit-bureau (АСОКИ/KATM) snapshot (Sheet b4). Several scoring factors + gates read this.
model CreditHistory {
  id                        String     @id @default(cuid())
  case                      CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId                    String     @unique
  repaidLoansCount          Int?
  activeLoansCount          Int?
  overdueSubstandardFlag    Int?
  otherObligations          Int?
  loansOver5MFlag           String?
  priorMfiPawnshopFlag      String?
  totalOutstandingDebt      Decimal?   @db.Decimal(18, 2)
  avgMonthlyPaymentExisting Decimal?   @db.Decimal(18, 2)
  committeeProtocolRef      String?
  committeeDecisionDate     DateTime?
}

/// Scoring outcome snapshot (Sheet балл + Score отчет). 20-factor breakdown in ScoringFactor.
model ScoringResult {
  id              String          @id @default(cuid())
  case            CreditCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId          String          @unique
  totalScore      Int
  maxScore        Int             @default(100)
  verdict         ScoringVerdict
  age             Float?
  monthlyTranches Decimal?        @db.Decimal(18, 2)
  monthlyIncome   Decimal?        @db.Decimal(18, 2)
  monthlyExpenses Decimal?        @db.Decimal(18, 2)
  surplus         Decimal?        @db.Decimal(18, 2)
  netAfterDebt    Decimal?        @db.Decimal(18, 2)
  computedAt      DateTime        @default(now())
  factors         ScoringFactor[]
}

model ScoringFactor {
  id        String        @id @default(cuid())
  result    ScoringResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  resultId  String
  factorNo  Int
  name      String
  points    Int
  maxPoints Int

  @@index([resultId])
}

/// Income certificate (Справка) — employer salary statement; 12 months → average net income.
model IncomeCertificate {
  id            String        @id @default(cuid())
  case          CreditCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId        String        @unique
  employer      String?
  position      String?
  certNo        String?
  certDate      DateTime?
  avgMonthlyNet Decimal?      @db.Decimal(18, 2)
  months        SalaryMonth[]
}

model SalaryMonth {
  id            String            @id @default(cuid())
  certificate   IncomeCertificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  certificateId String
  monthIndex    Int
  gross         Decimal?          @db.Decimal(18, 2)
  tax           Decimal?          @db.Decimal(18, 2)
  net           Decimal?          @db.Decimal(18, 2)

  @@index([certificateId])
}

/// Beneficiary bank requisites for the disbursement application (may be a third party's account).
model DisbursementDetail {
  id            String     @id @default(cuid())
  case          CreditCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId        String     @unique
  holderName    String?
  cardNumber    String?
  accountNumber String? // Х/Р (20-digit settlement account)
  bankMfo       String? // МФО
  holderInn     String? // account-holder ИНН (may differ from borrower.inn)
  bankName      String?
  updatedAt     DateTime   @updatedAt
}

// ── Audit trail (3 layers) ──────────────────────────────────────────────

enum AuditAction {
  RATE_CHANGE
  SPLIT_CHANGE
  KATM_PRICE
  CONFIG_CHANGE
  PAUSE
  RESUME
  CASE_CREATE
  CASE_UPDATE
  CASE_DELETE
  CASE_RESTORE
  SECTION_SAVE
  TRANSITION
  SIGN
  SIGN_FAILED
}

/// Layer A — semantic domain audit (who changed what value, from→to, and why).
model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  actor     User        @relation("AuditActor", fields: [actorId], references: [id])
  actorId   String
  role      Role
  case      CreditCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  caseId    String?
  field     String?
  oldValue  String?     @db.Text
  newValue  String?     @db.Text
  reason    String?     @db.Text
  createdAt DateTime    @default(now())

  @@index([caseId])
  @@index([actorId])
  @@index([action])
}

/// Layer B — every HTTP request.
model RequestLog {
  id         String   @id @default(cuid())
  method     String
  path       String   @db.Text
  userId     String?
  statusCode Int
  durationMs Int
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// Layer C — every Prisma query (separate store, pruned by retention cron).
model QueryLog {
  id         String   @id @default(cuid())
  model      String?
  action     String
  durationMs Int
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
