# Production env for docker-compose. Copy to deploy/.env and fill in real values.
# deploy/.env is gitignored — NEVER commit real secrets.

# MySQL (internal to the compose network; not exposed to the host in prod).
MYSQL_ROOT_PASSWORD=change-me-strong-password
# InnoDB buffer pool — caches data+indexes in RAM (default 128M is tiny). Tune to the server:
# ~50-70% of RAM on a DB-dedicated host; keep lower when the box also runs the backend + OCR.
MYSQL_BUFFER_POOL=512M
MYSQL_MAX_CONN=150

# OCR runs as 3 replicas (see docker-compose ocr) so several operators can scan at once. These are
# PER REPLICA. On a 12-core box: 3 replicas × OCR_CPUS(3) = 9 cores for OCR, ~3 left for the API.
#   OCR_MAX_CONCURRENT — scans at a time per replica (keep 1; 3 replicas already give 3 in parallel)
#   OCR_WORKERS        — tesseract workers per scan (parallel OCR passes); match it to OCR_CPUS
#   OCR_CPUS / OCR_MEM — hard CPU/RAM cap per replica
# Fewer/bigger replicas = faster single scans; more/smaller = more parallel but slower each.
OCR_MAX_CONCURRENT=1
OCR_WORKERS=4
OCR_CPUS=3
OCR_MEM=2500m

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Backend → mysql service on the compose network.
# ⚠️ The password here MUST be identical to MYSQL_ROOT_PASSWORD above — if they differ, every backend/
#    ocr/scheduler container fails to connect and crash-loops.
# connection_limit caps EACH app instance's Prisma pool. With 3 backend + 3 ocr + 1 scheduler = 7
# instances, 7×10 = 70 stays safely under MYSQL_MAX_CONN (150). Without it, each instance opens a pool
# of ~(cores×2+1) and the total can exceed max_connections → "Too many connections". Raise both if you
# add replicas.
DATABASE_URL=mysql://root:change-me-strong-password@mysql:3306/credit_core?connection_limit=10

# Baked into every web build. The api-client syncs the API scheme to the page scheme at
# runtime (http page -> http API, https page -> https API), so this only needs the right host;
# the scheme here is a default for non-browser contexts. nginx serves both :80 and :443.
VITE_API_URL=https://api.creditcore.uz

# CORS — the 4 role origins, both schemes (nginx serves http and https).
CORS_ORIGINS=http://operator.creditcore.uz,https://operator.creditcore.uz,http://moderator.creditcore.uz,https://moderator.creditcore.uz,http://director.creditcore.uz,https://director.creditcore.uz,http://admin.creditcore.uz,https://admin.creditcore.uz

# Let's Encrypt contact — nginx terminates TLS in-stack; certbot issues/renews the cert.
CERTBOT_EMAIL=khurshidi2827@gmail.com

# Where a scanned QR lands. The backend serves /v/<caseId> itself (outside the /api prefix), so
# this is the api host — https only: the URL is printed on paper and cannot be corrected later.
#
# This value is frozen into every signed document. Getting it wrong is not recoverable: the QR is
# encoded into the stored PDF, and the mistake only surfaces when someone first scans one, by
# which time the documents have been issued and cannot be reprinted. For that reason the backend
# REFUSES TO SIGN in production when this is unset, rather than quietly printing a localhost URL.
PUBLIC_VERIFY_URL=https://api.creditcore.uz
